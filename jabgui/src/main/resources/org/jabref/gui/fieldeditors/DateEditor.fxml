<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.HBox?>
<?import org.jabref.gui.fieldeditors.EditorTextField?>
<?import org.jabref.gui.util.component.TemporalAccessorPicker?>
<fx:root xmlns:fx="http://javafx.com/fxml/1" type="HBox" xmlns="http://javafx.com/javafx/8.0.112"
         fx:controller="org.jabref.gui.fieldeditors.DateEditor">
    <EditorTextField fx:id="textField" prefHeight="0" HBox.hgrow="ALWAYS" maxHeight="Infinity" maxWidth="Infinity"/>
    <TemporalAccessorPicker fx:id="datePicker" editable="false" focusTraversable="false" prefWidth="24.0"
                            minWidth="24.0" maxWidth="24.0" prefHeight="0" maxHeight="Infinity"/>
</fx:root>
