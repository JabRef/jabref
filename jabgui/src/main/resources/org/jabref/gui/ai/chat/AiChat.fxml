<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.jabref.gui.ai.AiPrivacyNoticeView?>
<?import org.jabref.gui.ai.statuspane.UniversalStatusPaneView?>
<?import org.jabref.gui.icon.JabRefIconView?>
<?import org.jabref.gui.util.component.HistoryTextArea?>
<?import org.jabref.gui.util.component.ListScrollPane?>
<?import org.jabref.gui.util.component.SimpleListView?>
<fx:root
        type="StackPane"
        xmlns="http://javafx.com/javafx"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="org.jabref.gui.ai.chat.AiChatView">

    <AiPrivacyNoticeView
            fx:id="privacyNotice"/>

    <UniversalStatusPaneView
            fx:id="noFilesErrorPane"
            title="%Unable to chat"
            description="%No files attached."/>

    <BorderPane
            fx:id="mainContainer"
            maxHeight="Infinity"
            maxWidth="Infinity">

        <padding>
            <Insets top="10"
                    right="10"
                    bottom="10"
                    left="10"/>
        </padding>

        <center>
            <StackPane>
                <ListScrollPane
                        fx:id="chatHistoryScrollPane"
                        fitToWidth="true"
                        fitToHeight="true"
                        spacing="10"
                        style="-fx-border-width: 1; -fx-border-color: black">
                    <contentPadding>
                        <Insets top="10"
                                right="10"
                                bottom="10"
                                left="10"/>
                    </contentPadding>
                </ListScrollPane>

                <Pane fx:id="transparentPane"
                      style="-fx-background-color: transparent;"/>

                <ProgressIndicator
                        fx:id="loadingIndicator"
                        maxWidth="50"
                        maxHeight="50"/>
            </StackPane>
        </center>

        <bottom>
            <VBox spacing="10">
                <padding>
                    <Insets top="10"/>
                </padding>

                <HBox fx:id="followUpQuestionsArea"
                      spacing="5"
                      alignment="CENTER">
                    <Label text="%Follow-up questions"/>

                    <SimpleListView
                            fx:id="followUpQuestionsSimpleListView"
                            spacing="10"/>
                </HBox>


                <BorderPane>
                    <left>
                        <Button fx:id="infoButton"
                                onAction="#showInfo"
                                styleClass="icon-button,narrow"
                                textAlignment="CENTER"
                                BorderPane.alignment="CENTER">
                            <graphic>
                                <JabRefIconView
                                        glyph="INTEGRITY_INFO"/>
                            </graphic>
                            <tooltip>
                                <Tooltip
                                        text="%View ingestion status"/>
                            </tooltip>
                            <BorderPane.margin>
                                <Insets right="10"/>
                            </BorderPane.margin>
                        </Button>
                    </left>

                    <center>
                        <HBox spacing="10"
                              alignment="CENTER">
                            <HistoryTextArea
                                    fx:id="userMessageTextArea"
                                    onSubmit="#send"
                                    HBox.hgrow="ALWAYS"/>
                            <Button fx:id="sendButton"
                                    text="%Send"
                                    onAction="#send"/>
                            <Button fx:id="retryButton"
                                    text="%Retry"
                                    onAction="#retry"/>
                            <Button fx:id="cancelButton"
                                    text="%Cancel"
                                    onAction="#cancel"/>
                        </HBox>
                    </center>
                </BorderPane>

                <Label fx:id="noticeText"
                       maxWidth="Infinity"
                       alignment="CENTER"
                       textAlignment="CENTER"
                       wrapText="true"/>
            </VBox>
        </bottom>
    </BorderPane>
</fx:root>
