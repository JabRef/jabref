<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>
<?import org.jabref.gui.icon.JabRefIconView?>
<fx:root
        type="VBox"
        xmlns="http://javafx.com/javafx"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="org.jabref.gui.ai.summary.AiSummaryShowingView"
        spacing="10.0">
    <padding>
        <Insets bottom="10.0"
                left="10.0"
                right="10.0"
                top="10.0"/>
    </padding>

    <BorderPane>
        <left>
            <CheckBox
                    fx:id="markdownCheckbox"
                    mnemonicParsing="false"
                    selected="true"
                    text="Markdown"/>
        </left>
        <center>
            <HBox spacing="10.0"
                  alignment="CENTER">
                <Button mnemonicParsing="false"
                        text="%Regenerate"
                        onAction="#regenerate"/>
                <Button mnemonicParsing="false"
                        text="%Regenerate (custom)"
                        onAction="#regenerateCustom"/>
            </HBox>
        </center>
        <right>
            <MenuButton
                    mnemonicParsing="false"
                    text="%Export">
                <graphic>
                    <JabRefIconView
                            glyph="SAVE"/>
                </graphic>
                <items>
                    <MenuItem
                            text="%Export to JSON..."
                            onAction="#exportJson"/>
                    <MenuItem
                            text="%Export to Markdown..."
                            onAction="#exportMarkdown"/>
                </items>
            </MenuButton>
        </right>
    </BorderPane>

    <VBox alignment="BASELINE_CENTER">
        <Text fx:id="summaryInfoText"
              textAlignment="CENTER"
              strokeType="OUTSIDE"
              strokeWidth="0.0"
              text="%Generated at %0 by %1 (algorithm %2)"/>
    </VBox>
</fx:root>
