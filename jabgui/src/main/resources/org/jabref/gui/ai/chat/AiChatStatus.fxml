<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.jabref.gui.icon.JabRefIconView?>
<fx:root
        type="VBox"
        xmlns="http://javafx.com/javafx"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="org.jabref.gui.ai.chat.AiChatStatusView"
        spacing="10">

    <padding>
        <Insets top="10"
                right="10"
                bottom="10"
                left="10"/>
    </padding>

    <Label text="%Chat Status"
           styleClass="titleHeader"/>

    <VBox spacing="10">
        <Label text="%Chatting parameters"
               styleClass="sectionHeader"/>

        <HBox spacing="10"
              alignment="CENTER_LEFT">
            <Label text="%Chat model"/>
            <Label fx:id="chatModelLabel"/>
        </HBox>

        <HBox spacing="10"
              alignment="CENTER_LEFT">
            <Label text="%Answer engine"/>
            <ComboBox
                    fx:id="answerEngineComboBox"
                    prefWidth="200"/>
        </HBox>


    </VBox>

    <VBox spacing="10"
          VBox.vgrow="ALWAYS">
        <Label text="%Entries in the chat"
               styleClass="sectionHeader"/>
        <TableView
                fx:id="entriesTable"
                VBox.vgrow="ALWAYS"
                prefHeight="150">
            <columns>
                <TableColumn
                        fx:id="libraryColumn"
                        text="%Library"/>
                <TableColumn
                        fx:id="citationKeyColumn"
                        text="%Citation Key"/>
            </columns>
            <columnResizePolicy>
                <TableView
                        fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>

    <VBox spacing="10"
          VBox.vgrow="ALWAYS">
        <Label text="%Ingestion status"
               styleClass="sectionHeader"/>
        <TableView
                fx:id="ingestionTable"
                VBox.vgrow="ALWAYS"
                prefHeight="200">
            <columns>
                <TableColumn
                        fx:id="fileColumn"
                        text="%File"/>
                <TableColumn
                        fx:id="statusColumn"
                        text="%Status"
                        maxWidth="150"
                        minWidth="100"/>
                <TableColumn
                        fx:id="actionColumn"
                        text="%Action"
                        maxWidth="120"
                        minWidth="100"/>
            </columns>
            <columnResizePolicy>
                <TableView
                        fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </VBox>

    <HBox spacing="10"
          alignment="CENTER_LEFT">

        <MenuButton
                mnemonicParsing="false"
                alignment="BASELINE_LEFT"
                text="%Export chat history">
            <graphic>
                <JabRefIconView
                        glyph="SAVE"/>
            </graphic>
            <items>
                <MenuItem
                        text="%Export to JSON..."
                        onAction="#exportJson"/>
                <MenuItem
                        text="%Export to Markdown..."
                        onAction="#exportMarkdown"/>
            </items>
        </MenuButton>

        <Region HBox.hgrow="ALWAYS"/>

        <Button
                onAction="#clearChatHistory"
                alignment="BASELINE_RIGHT"
                text="%Clear chat history"
                textAlignment="CENTER">
            <graphic>
                <JabRefIconView
                        glyph="DELETE_ENTRY"/>
            </graphic>
        </Button>
    </HBox>

</fx:root>
