<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ContextMenu?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.jabref.gui.icon.JabRefIconView?>
<fx:root
        type="javafx.scene.layout.HBox"
        xmlns="http://javafx.com/javafx"
        xmlns:fx="http://javafx.com/fxml"
        spacing="10"
        HBox.hgrow="ALWAYS"
        fx:controller="org.jabref.gui.ai.chat.AiChatMessageView">

    <VBox fx:id="bubble"
          styleClass="chat-bubble">
        <Label fx:id="sourceLabel"
               style="-fx-font-weight: bold;"/>

        <StackPane
                fx:id="markdownContentPane"/>
    </VBox>

    <fx:define>
        <ContextMenu
                fx:id="contextMenu">
            <items>
                <MenuItem
                        text="%Copy to clipboard"
                        onAction="#onCopyContextMenuClick"/>
            </items>
        </ContextMenu>

    </fx:define>

    <VBox fx:id="buttons"
          alignment="TOP_CENTER"
          spacing="5">
        <Button fx:id="deleteButton"
                onAction="#onDeleteClick"
                styleClass="icon-button,narrow">
            <graphic>
                <JabRefIconView
                        glyph="DELETE_ENTRY"/>
            </graphic>
        </Button>

        <Button fx:id="regenerateButton"
                onAction="#onRegenerateClick"
                styleClass="icon-button,narrow">
            <graphic>
                <JabRefIconView
                        glyph="REFRESH"/>
            </graphic>
        </Button>
    </VBox>

</fx:root>
